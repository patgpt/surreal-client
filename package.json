{
	"name": "surreal-codegen",
	"private": false,
	"version": "0.1.1",
	"type": "module",
	"engines": {
		"bun": ">=1.1.0"
	},
	"packageManager": "bun@1.3.5",
	"description": "Generate Zod schemas and a typed TypeScript client from a SurrealDB schema or live database",
	"keywords": [
		"typescript",
		"surrealdb",
		"surrealql",
		"surql",
		"schemafull",
		"client",
		"javascript",
		"zod",
		"orm",
		"database",
		"generator",
		"tool"
	],
	"author": {
		"name": "Patrick Kelly",
		"url": "https://github.com/patgpt"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/patgpt/surreal-client.git"
	},
	"homepage": "https://github.com/patgpt/surreal-client#readme",
	"bugs": {
		"url": "https://github.com/patgpt/surreal-client/issues"
	},
	"license": "MIT",
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"bin": {
		"surreal-codegen": "./dist/index.js",
		"surql-gen": "./dist/index.js"
	},
	"scripts": {
		"clean": "node clean.mjs",
		"start": "bun dist/index.js",
		"dev": "bun src/index.ts",
		"build": "bun run clean && bun run ./build.ts && bunx tsc -p tsconfig.build.json",
		"ci": "bun run lint && bun run typecheck && bun run test && bun run build",
		"pack:dry-run": "npm pack --dry-run --cache ./.npm",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"lint": "biome lint .",
		"lint:fix": "biome check --write .",
		"test": "bun test",
		"prepublishOnly": "bun run ci"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.15",
		"@types/bun": "^1.3.11",
		"@types/figlet": "^1.7.0",
		"@types/gradient-string": "^1.1.6",
		"@types/node": "^25.2.3",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@clack/prompts": "^1.1.0",
		"boxen": "^8.0.1",
		"chalk": "^5.6.2",
		"figlet": "^1.11.0",
		"gradient-string": "^3.0.0",
		"mkdirp": "^3.0.1",
		"rimraf": "^6.1.2",
		"surrealdb": "^2.0.3",
		"testcontainers": "^11.11.0",
		"zod": "^4.3.6"
	},
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts"
}

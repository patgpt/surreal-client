{
  "name": "sureal-codegen",
  "private": false,
  "version": "0.0.1",
  "engines": {
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.5",
  "description": "A small tool which generates a typescript client for SurrealDB based on the schema of a given database",
  "keywords": [
    "typescript",
    "surrealdb",
    "client",
    "javascript",
    "zod",
    "orm",
    "database",
    "generator",
    "tool"
  ],
  "author": {
    "name": "Patrick Kelly",
    "url": "https://github.com/patgpt"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/patgpt/sureal-codegen.git"
  },
  "homepage": "https://github.com/patgpt/sureal-codegen",
  "bugs": {
    "url": "https://github.com/patgpt/sureal-codegen/issues",
    "email": "project@hostname.com"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "bin": {
    "surreal-codegen": "./dist/index.js",
    "surql-gen": "./dist/index.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "start": "bun dist/index.js",
    "dev": "bun src/index.ts",
    "build": "bun run clean && bun build src/index.ts --outdir dist --format esm --target bun --minify",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check --write .",
    "test": "bun test",
    "prepublishOnly": "bun run typecheck && bun test && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@types/bun": "^1.3.11",
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "mkdirp": "^3.0.1",
    "rimraf": "^6.1.2",
    "surrealdb": "^2.0.3",
    "testcontainers": "^11.11.0",
    "zod": "^4.3.6"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "default": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js"
}
